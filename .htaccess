<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Hanya jalankan aturan untuk domain quizb.my.id
  RewriteCond %{HTTP_HOST} !^(www\.)?quizb\.my\.id$ [NC]
  RewriteRule ^ - [L]

  # Cegah loop ketika request sudah dialihkan ke subfolder
  RewriteCond %{REQUEST_URI} ^/up\.quizb\.my\.id/ [NC]
  RewriteRule ^ - [L]

  # Mapping eksplisit
  RewriteRule ^assets/(.*)$ /up.quizb.my.id/assets/$1 [QSA,L,NC]
  RewriteRule ^favicon\.ico$ /up.quizb.my.id/favicon.ico [L,NC]
  RewriteRule ^robots\.txt$ /up.quizb.my.id/robots.txt [L,NC]

  # API pretty URLs: /api/{namespace}/{method} -> /up.quizb.my.id/api.php?action=namespace.method
  RewriteRule ^api/([^/]+)/([^/]+)/?$ /up.quizb.my.id/api.php?action=$1.$2 [QSA,L,NC]
  # Optional: /api/{namespace} -> call index (api.php?action=namespace.index)
  RewriteRule ^api/([^/]+)/?$ /up.quizb.my.id/api.php?action=$1.index [QSA,L,NC]

  # Root (beranda) -> subfolder
  RewriteRule ^$ /up.quizb.my.id/ [QSA,L]

  # Fallback: semua request lain ke subfolder
  RewriteRule ^(.*)$ /up.quizb.my.id/$1 [QSA,L]
</IfModule>

# End of .htaccess
